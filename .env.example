# API base (NestJS server)
VITE_API_URL=http://localhost:3001/api/v1

# Auth mode: "dev" uses the server's dev-login seam (no AWS needed);
# "cognito" uses AWS Cognito via Amplify.
VITE_AUTH_MODE=dev

# Required when VITE_AUTH_MODE=cognito:
VITE_AWS_REGION=us-east-1
VITE_COGNITO_USER_POOL_ID=
VITE_COGNITO_USER_POOL_CLIENT_ID=

# Premade demo account for the "Explore as a demo recruiter" button.
# In cognito mode these must match a confirmed Cognito user in the `agent` group.
VITE_DEMO_EMAIL=demo@georgegarciadev.com
VITE_DEMO_PASSWORD=
